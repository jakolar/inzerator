# Inzerator server environment.
# Copy to .env (gitignored) and fill in real values.
# Load before starting the server:
#   set -a; source .env; set +a; python3 server.py

# OpenAI API key — used by /api/image-edit (gpt-image-1).
# Get one from https://platform.openai.com/api-keys
# Cost per request: ~$0.19 for high-quality 1024² edit; ~$0.40 for 1536×1024.
OPENAI_API_KEY=sk-proj-...

# Shared secret protecting /api/image-edit on open LAN. Without this set,
# the endpoint refuses with 503 — that's intentional, since OpenAI billing
# attaches to OPENAI_API_KEY and we don't want random LAN clients spending
# it. Generate something unguessable, e.g.:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(24))'
INZERATOR_API_TOKEN=replace-me-with-a-random-string

# Optional — port override (default 8080).
# PORT=8080

# Optional — ČÚZK cache directory used by gen_heightfield / refresh_ortho.
# Defaults to ../inzerator_data/cache if unset.
# INZERATOR_CACHE=/path/to/cache

# Optional — full URL of this server, used by gen_heightfield's
# /proxy/cadastre + /api/parcels calls (it shells out to a child Python
# process that needs to reach the same server). Default http://127.0.0.1:8080.
# INZERATOR_PROXY=http://127.0.0.1:8080
